root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
indent_style = space
indent_size = 4

[*.{rs,ron}]
max_line_length = 100

[*.{json,yml}]
indent_size = 2

[*.md]
# Double whitespace at end of line denotes a line break
trim_trailing_whitespace = false
